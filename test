      window.updateArrowVisibility = function(container) {
        if (!container) return;
        const leftArrow = container.parentElement.querySelector('.left-arrow');
        const rightArrow = container.parentElement.querySelector('.right-arrow');
        if (!leftArrow || !rightArrow) return;
        
        const canScrollLeft = container.scrollLeft > 0;
        const canScrollRight = container.scrollWidth > container.clientWidth + container.scrollLeft;
        
        leftArrow.style.display = canScrollLeft ? 'flex' : 'none';
        rightArrow.style.display = canScrollRight ? 'flex' : 'none';
      };

