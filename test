      async function loadArtworkData() {
        const container = document.getElementById('artworkGrid');
        const data = currentState.data;
        const isAnime = currentState.source === 'jikan';
        
        container.innerHTML = '<p class="loading-text" style="grid-column:1/-1;padding:20px 0;">Loading artwork...</p>';

        let images = []; // { type, url (full), thumb (display) }

        if (isAnime) {
          // Add main images first
          const jpg = data.images?.jpg;
          const webp = data.images?.webp;
          if (jpg?.large_image_url) images.push({ type: 'poster', url: jpg.large_image_url, thumb: jpg.large_image_url });
          if (webp?.large_image_url && webp.large_image_url !== jpg?.large_image_url)
            images.push({ type: 'poster', url: webp.large_image_url, thumb: webp.large_image_url });

          // Fetch /pictures for all extra images
          try {
            const res = await fetch(`https://api.jikan.moe/v4/anime/${currentState.id}/pictures`);
            if (res.ok) {
              const { data: pics } = await res.json();
              (pics || []).forEach(pic => {
                const url = pic.jpg?.large_image_url || pic.jpg?.image_url
                         || pic.webp?.large_image_url || pic.webp?.image_url;
                // Use large_image_url for both thumb and full — avoids the blurry small thumbnails
                const thumb = pic.jpg?.large_image_url || pic.webp?.large_image_url || url;
                if (url && !images.some(i => i.url === url)) {
                  images.push({ type: 'poster', url, thumb });
                }
              });
            }
          } catch(e) { /* use what we have */ }

        } else {
          // TMDB — use w500 for poster thumbs, w780 for backdrop thumbs, w1280 for full
          const tmdbImgs = data.images || {};

          // Fallback: if images weren't appended (old cache), build from main poster/backdrop
          if (!tmdbImgs.posters?.length && !tmdbImgs.backdrops?.length) {
            if (data.poster_path) images.push({
              type: 'poster',
              url: `https://image.tmdb.org/t/p/original${data.poster_path}`,
              thumb: `https://image.tmdb.org/t/p/w500${data.poster_path}`
            });
            if (data.backdrop_path) images.push({
              type: 'backdrop',
              url: `https://image.tmdb.org/t/p/original${data.backdrop_path}`,
              thumb: `https://image.tmdb.org/t/p/w780${data.backdrop_path}`
            });
          }

          (tmdbImgs.posters || []).slice(0, 12).forEach(p => images.push({
            type: 'poster',
            url: `https://image.tmdb.org/t/p/original${p.file_path}`,
            thumb: `https://image.tmdb.org/t/p/w500${p.file_path}`
          }));
          (tmdbImgs.backdrops || []).slice(0, 10).forEach(b => images.push({
            type: 'backdrop',
            url: `https://image.tmdb.org/t/p/original${b.file_path}`,
            thumb: `https://image.tmdb.org/t/p/w780${b.file_path}`
          }));
          (tmdbImgs.logos || []).slice(0, 5).forEach(l => images.push({
            type: 'logo',
            url: `https://image.tmdb.org/t/p/original${l.file_path}`,
            thumb: `https://image.tmdb.org/t/p/w500${l.file_path}`
          }));
        }
        
        if (!images.length) {
          container.innerHTML = '<p class="loading-text" style="grid-column:1/-1;">No artwork available</p>';
          return;
        }

        const typeLabel = { poster: 'Poster', backdrop: 'Backdrop', logo: 'Logo' };
        container.innerHTML = images.map(img => `
          <div class="artwork-item artwork-item--${img.type}"
               onclick="document.getElementById('lightboxImg').src='${escapeHtml(img.url)}';document.getElementById('artworkLightbox').classList.add('show')">
            <img src="${escapeHtml(img.thumb)}" data-full="${escapeHtml(img.url)}"
                 alt="${typeLabel[img.type] || 'Artwork'}" loading="lazy"
                 onerror="this.closest('.artwork-item').style.display='none'">
            <span class="artwork-type-badge">${typeLabel[img.type] || ''}</span>
          </div>
        `).join('');
      }

