<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Aniocean - Show Details</title>
  <meta name="description" content="Stream anime, movies, and TV shows on Aniocean">
  
  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=Inter:wght@400;500;600;700&family=Poppins:wght@400;500;600&display=swap" rel="stylesheet">
  
  <!-- Font Awesome -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  
  <!-- Shared CSS/JS -->
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
  <script src="/shared.js"></script>
  
  <!-- Page-specific CSS -->
  <style>
 /* ========================================
   ANIOCEAN - SHOW INFO PAGE STYLES
   Uses CSS Variables from shared.js theme
   Layout matched to index.html
   ======================================== */

:root {
  /* Layout - MATCHED TO index.html (68% main, 32% sidebar) */
  --max-width: 100%;
  --main-width: 68%;
  --sidebar-width: 32%;
  --gutter: 16px;
  --content-padding: 16px;
  
  --bg-body: #0a1929;
  --bg-header: #0f2440;
  --bg-card: #132f4c;
  --bg-surface: #1a3a5c;
  --bg-popup: #102a44;
  --text-primary: #ffffff;
  --text-secondary: #b0c7e3;
  --text-muted: #94a3b8;
  --text-widget-title: #a2c4de;
  --btn-primary: #2b6cb0;
  --btn-primary-hover: #1d4e89;
  --btn-primary-text: #ffffff;
  --btn-secondary: #334e68;
  --btn-secondary-hover: #243b53;
  --popup-btn: #5c6ac4;
  --popup-btn-text: #ffffff;
  --popup-btn-hover: #4955b5;
  --genre-tag-bg: #4c51bf;
  --link-accent: #ed64a6;
  --accent-gold: #ecc94b;
  --accent-blue: #4299e1;
  --border-subtle: rgba(255, 255, 255, 0.08);
  --border-medium: rgba(255, 255, 255, 0.16);
  --font-title: 'Archivo Black', sans-serif;
  --font-body: 'Inter', sans-serif;
  --font-meta: 'Poppins', sans-serif;
  --radius-sm: 6px;
  --radius-md: 12px;
  --radius-lg: 18px;
  --radius-pill: 50px;
  --radius-circle: 50%;
  --shadow-lg: 0 20px 60px rgba(0,0,0,0.5);
  --transition-fast: 0.18s ease;
}

/* Prevent browser smooth-scroll from causing perceived auto-scroll on load */
html { scroll-behavior: auto; }

/* Reset & Base */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
body { 
  font-family: 'Inter', system-ui, sans-serif; 
  background: var(--bg-body); 
  color: var(--text-primary);
  line-height: 1.5;
}
a { color: inherit; text-decoration: none; }
button { font: inherit; cursor: pointer; background: none; border: none; color: inherit; }
img { max-width: 100%; height: auto; display: block; }

/* Breadcrumbs */
.breadcrumbs {
  padding: 16px var(--gutter);
  max-width: var(--max-width);
  margin: 0 auto;
}
.breadcrumbs ol {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 4px;
  font-size: 0.85rem;
  list-style: none;
}
.breadcrumbs li {
  display: flex;
  align-items: center;
  gap: 6px;
}
.breadcrumbs a {
  color: var(--text-secondary);
  transition: color 0.15s;
  display: flex;
  align-items: center;
  gap: 4px;
}
.breadcrumbs a:hover { color: var(--text-primary); }
.breadcrumbs .current { color: var(--text-muted); font-weight: 500; }
.breadcrumbs-separator {
  color: var(--text-muted);
  font-size: 0.7rem;
  opacity: 0.7;
}
.breadcrumb-current {
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 280px;
  display: block;
}

/* Backdrop */
.backdrop-container {
  position: relative;
  width: 100%;
  height: auto;
  aspect-ratio: 16 / 5.5;
  min-height: 300px;
  max-height: 450px;
  overflow: hidden;
}
.backdrop-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center 30%;
  image-rendering: -webkit-optimize-contrast;
  image-rendering: crisp-edges;
}
.backdrop-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    180deg,
    transparent 0%,
    rgba(10, 25, 41, 0.4) 40%,
    var(--bg-body) 100%
  );
  pointer-events: none;
}

/* Main grid layout - MATCHED TO INDEX.HTML */
.info-grid {
  display: flex;
  gap: 0;
  max-width: 100%;
  margin: 0 auto;
  padding: 0 var(--gutter) var(--gutter);
  width: 100%;
}

/* Main content wrapper - 68% like index.html */
.main-content {
  flex: 0 0 var(--main-width);
  max-width: var(--main-width);
  padding: 0 var(--content-padding);
  min-width: 0;
}

/* Sidebar - 32% like index.html */
.sidebar {
  flex: 0 0 var(--sidebar-width);
  max-width: var(--sidebar-width);
  padding: 0 var(--content-padding) 0 8px;
  position: sticky;
  top: 80px;
  align-self: start;
  max-height: calc(100vh - 100px);
  overflow-y: auto;
}

/* Combined sidebar container - ALL SECTIONS IN ONE */
.sidebar-combined {
  background: var(--bg-card);
  border: 1px solid var(--border-subtle);
  border-radius: var(--radius-md);
  overflow: hidden;
  height: 100%;
  display: flex;
  flex-direction: column;
}

.sidebar-section {
  margin: 0;
  border-bottom: 1px solid var(--border-subtle);
}

.sidebar-section:last-child {
  border-bottom: none;
}

.sidebar-section h4 {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 10px 12px;
  background: var(--bg-surface);
  font-size: 0.78rem;
  font-weight: 700;
  color: #fff;
  margin: 0;
  border-bottom: 1px solid var(--border-subtle);
}

.sidebar-list {
  padding: 8px;
  max-height: 280px;
  overflow-y: auto;
  overflow-x: hidden;
}

/* Custom scrollbar for sidebar lists */
.sidebar-list::-webkit-scrollbar {
  width: 4px;
}

.sidebar-list::-webkit-scrollbar-track {
  background: rgba(255,255,255,0.05);
}

.sidebar-list::-webkit-scrollbar-thumb {
  background: var(--border-medium);
  border-radius: 2px;
}

.sidebar-list::-webkit-scrollbar-thumb:hover {
  background: var(--btn-primary);
}

.sidebar-list-item {
  display: flex;
  gap: 10px;
  align-items: center;
  padding: 8px;
  border-radius: var(--radius-sm);
  cursor: pointer;
  transition: background var(--transition-fast);
  margin-bottom: 4px;
  text-decoration: none;
  color: inherit;
}

.sidebar-list-item:hover {
  background: var(--bg-surface);
}

.sidebar-list-item:last-child {
  margin-bottom: 0;
}

.sidebar-rank {
  font-size: 1.4rem;
  font-weight: 700;
  color: rgba(255,255,255,0.12);
  width: 30px;
  text-align: center;
  flex-shrink: 0;
  font-family: var(--font-title);
}

.sidebar-poster {
  width: 50px;
  height: 70px;
  object-fit: cover;
  border-radius: var(--radius-sm);
  flex-shrink: 0;
  background: var(--bg-card);
}

.sidebar-info h4 {
  font-size: 0.8rem;
  font-weight: 600;
  color: #fff;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  white-space: normal;
  line-height: 1.3;
  margin: 0;
}

.side-meta {
  font-size: 0.6875rem;
  color: var(--text-muted);
  margin-top: 2px;
}

/* Hero Section */
.hero-section {
  display: grid;
  grid-template-columns: auto 1fr;
  gap: 24px;
  align-items: start;
  margin-top: -60px;
  position: relative;
  z-index: 10;
  padding-bottom: 24px;
}

.poster-wrapper {
  position: relative;
  width: 220px;
  flex-shrink: 0;
}
.poster-img {
  width: 100%;
  border-radius: 12px;
  box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.75);
  aspect-ratio: 2/3;
  object-fit: cover;
  background: var(--bg-surface);
}

.language-badges {
  position: absolute;
  bottom: 12px;
  left: 12px;
  display: flex;
  flex-direction: column;
  gap: 6px;
  z-index: 2;
}
.lang-badge {
  display: flex;
  align-items: center;
  gap: 4px;
  padding: 4px 10px;
  border-radius: 20px;
  font-size: 0.7rem;
  font-weight: 600;
  color: #fff;
  backdrop-filter: blur(4px);
}
.lang-badge.sub {
  background: rgba(49, 132, 192, 0.2);
  border: 1px solid #3184c4;
}
.lang-badge.dub {
  background: rgba(239, 68, 68, 0.2);
  border: 1px solid #ef4444;
}

.episode-badge {
  position: absolute;
  bottom: 12px;
  right: 12px;
  padding: 6px 12px;
  background: rgba(0,0,0,0.7);
  border: 1px solid var(--border-medium);
  border-radius: 20px;
  font-size: 0.75rem;
  font-weight: 700;
  color: var(--accent-gold);
}

.title-meta-container {
  padding-top: 8px;
}
.show-title {
  font-family: 'Archivo Black', sans-serif;
  font-size: 2rem;
  line-height: 1.2;
  margin-bottom: 12px;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* Metadata Row */
.metadata-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  font-size: 0.85rem;
  color: var(--text-secondary);
  margin-bottom: 20px;
}
.metadata-row::before { content: ''; }
.metadata-row span:not(:last-child)::after {
  content: '•';
  margin-left: 8px;
  color: var(--text-muted);
}

/* Action Buttons */
.action-buttons {
  flex-direction: row;
  justify-content: center;
  flex-wrap: wrap;
}
.btn { width: auto; }
.btn-icon-only {
  width: 40px;
  height: 40px;
}
.btn-primary {
  background: var(--btn-primary);
  color: #fff;
}
.btn-primary:hover {
  background: var(--btn-primary-hover);
  transform: translateY(-1px);
}
.btn-secondary {
  background: var(--bg-surface);
  color: var(--text-secondary);
  border: none;
}
.btn-secondary:hover {
  background: rgba(255,255,255,0.1);
  color: var(--text-primary);
}
.btn-icon-only {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-surface);
  color: var(--text-secondary);
  transition: all 0.18s;
}
.btn-icon-only:hover {
  background: var(--btn-primary);
  color: #fff;
}

/* Dropdown Menu */
.dropdown-container { position: relative; }
.dropdown-arrow { transition: transform 0.2s; font-size: 0.7rem; }
.dropdown-container.open .dropdown-arrow { transform: rotate(180deg); }

.dropdown-menu {
  position: absolute;
  top: calc(100% + 8px);
  left: 0;
  background: var(--bg-card);
  border: 1px solid var(--border-medium);
  border-radius: 12px;
  padding: 8px;
  min-width: 220px;
  z-index: 100;
  display: none;
  flex-direction: column;
  gap: 4px;
  box-shadow: 0 20px 40px rgba(0,0,0,0.4);
}
.dropdown-menu.show { display: flex; }
.dropdown-item {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 12px;
  border-radius: 8px;
  font-size: 0.85rem;
  color: var(--text-secondary);
  transition: background 0.15s;
  cursor: pointer;
}
.dropdown-item:hover {
  background: rgba(255,255,255,0.08);
  color: var(--text-primary);
}
.dropdown-item.selected {
  background: rgba(43, 108, 176, 0.2);
  color: #68d391;
}
.dropdown-item.selected .bk-check-icon {
  margin-left: auto;
  color: #48bb78;
  font-size: 0.85rem;
}
.status-icon { flex-shrink: 0; }

/* Stats Container */
.stats-container {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16px;
  background: var(--bg-card);
  border: 1px solid var(--border-subtle);
  border-radius: 16px;
  padding: 16px 20px;
  margin-bottom: 24px;
}
.stat-column {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 8px;
}
.stat-label {
  font-size: 0.75rem;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.05em;
  margin-bottom: 4px;
}
.stat-value {
  font-size: 1.25rem;
  font-weight: 700;
  display: flex;
  align-items: center;
  gap: 4px;
}
.stat-value-rating {
  font-size: 0.9rem;
  font-weight: 700;
  color: var(--text-secondary);
}
.star-icon { color: var(--accent-gold); }

/* Synopsis */
.synopsis-container {
  background: var(--bg-card);
  border: 1px solid var(--border-subtle);
  border-radius: 16px;
  margin-bottom: 24px;
  overflow: hidden;
}
.synopsis-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14px 20px;
  border-bottom: 1px solid var(--border-subtle);
}
.synopsis-header h3 {
  font-size: 1.1rem;
  font-weight: 700;
}
.expand-btn {
  display: flex;
  align-items: center;
  gap: 4px;
  font-size: 0.8rem;
  color: var(--accent-cyan);
  font-weight: 600;
}
.expand-icon { transition: transform 0.2s; }
.expand-btn.expanded .expand-icon { transform: rotate(180deg); }

.synopsis-content {
  max-height: 120px;
  overflow: hidden;
  transition: max-height 0.3s ease;
  padding: 0 20px;
}
.synopsis-content.expanded { max-height: 2000px; }
.synopsis-content p {
  padding: 16px 0;
  font-size: 0.95rem;
  color: var(--text-secondary);
  line-height: 1.7;
}

/* Details Section */
.details-section {
  margin-bottom: 32px;
}
.details-section h3 {
  font-size: 1.2rem;
  margin-bottom: 16px;
  padding-bottom: 12px;
  border-bottom: 1px solid var(--border-subtle);
}
.details-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12px 24px;
}
.detail-item {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12px;
  padding: 4px 0;
}
.detail-label {
  font-size: 0.8rem;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.03em;
  min-width: 100px;
  flex-shrink: 0;
}
.detail-value {
  font-size: 0.95rem;
  color: var(--text-secondary);
  text-align: right;
  flex: 1;
  word-break: break-word;
}
.detail-value a {
  color: var(--accent-cyan);
  transition: color 0.15s;
}
.detail-value a:hover { color: var(--btn-primary-hover); }

/* Genre Tags */
.genre-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  justify-content: flex-end;
}
.genre-tag {
  padding: 4px 12px;
  border-radius: 20px;
  font-size: 0.8rem;
  font-weight: 500;
  background: var(--bg-surface);
  border: 1px solid var(--border-medium);
  transition: background 0.15s;
}
.genre-tag:hover {
  background: rgba(43, 108, 176, 0.2);
  border-color: var(--btn-primary);
}
.genre-tag[data-start="a"] { background: rgba(49, 132, 192, 0.15); border-color: rgba(49, 132, 192, 0.4); }
.genre-tag[data-start="b"] { background: rgba(16, 185, 129, 0.15); border-color: rgba(16, 185, 129, 0.4); }
.genre-tag[data-start="c"] { background: rgba(236, 201, 75, 0.15); border-color: rgba(236, 201, 75, 0.4); }
.genre-tag[data-start="d"] { background: rgba(239, 68, 68, 0.15); border-color: rgba(239, 68, 68, 0.4); }
.genre-tag[data-start="f"] { background: rgba(139, 92, 246, 0.15); border-color: rgba(139, 92, 246, 0.4); }
.genre-tag[data-start="h"] { background: rgba(249, 115, 22, 0.15); border-color: rgba(249, 115, 22, 0.4); }
.genre-tag[data-start="m"] { background: rgba(59, 130, 246, 0.15); border-color: rgba(59, 130, 246, 0.4); }
.genre-tag[data-start="r"] { background: rgba(236, 72, 153, 0.15); border-color: rgba(236, 72, 153, 0.4); }
.genre-tag[data-start="s"] { background: rgba(34, 197, 94, 0.15); border-color: rgba(34, 197, 94, 0.4); }

/* External Links */
.external-links {
  display: flex;
  gap: 12px;
  justify-content: flex-end;
  margin-top: 8px;
}
.ext-link-btn {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 8px 14px;
  border-radius: 10px;
  font-size: 0.85rem;
  font-weight: 600;
  background: var(--bg-surface);
  border: 1px solid var(--border-medium);
  transition: all 0.18s;
}
.ext-link-btn:hover {
  background: var(--btn-primary);
  border-color: var(--btn-primary);
  transform: translateY(-1px);
}
.ext-link-btn.mal { color: #2e51a2; }
.ext-link-btn.tmdb { color: #01b4e4; }

/* Seasons Section */
.seasons-section { margin-bottom: 32px; }
.seasons-section h3 { margin-bottom: 16px; }

/* NEW: Scroll container for seasons - same as cast/crew but with hidden scrollbar */
.seasons-scroll-container {
  max-height: 500px;
  overflow-y: auto;
  overflow-x: hidden;
  border-radius: var(--radius-md);
  /* Hide scrollbar completely while keeping functionality */
  scrollbar-width: none; /* Firefox */
  -ms-overflow-style: none; /* IE/Edge */
}
.seasons-scroll-container::-webkit-scrollbar {
  display: none; /* Chrome, Safari, Opera */
}

/* The seasons grid stays as original 2-column layout inside scroll container */
.seasons-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16px;
  padding: 2px; /* tiny space for focus/hover, not clip */
}

.season-card {
  position: relative;
  aspect-ratio: 16/7;
  border-radius: 12px;
  overflow: hidden;
  cursor: pointer;
  transition: transform 0.2s, box-shadow 0.2s;
}
.season-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 20px 40px rgba(0,0,0,0.4);
}
.season-card::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, transparent 30%, rgba(0,0,0,0.85) 100%);
  z-index: 1;
}
.season-card img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  filter: brightness(0.85);
}
.season-number {
  font-weight: 700;
  font-size: 0.9rem;
  color: #fff;
  text-align: center;
  padding: 6px 20px;
  background: rgba(43, 108, 176, 0.95);
  border-radius: 20px;
  backdrop-filter: blur(4px);
  max-width: 90%;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* ── Tabs Section ─────────────────────────────────── */
.tabs-section { margin-bottom: 32px; }

/* ── Desktop: radio + glider sliding tabs ── */
.tabs-radio-wrap {
  display: none; /* hidden on mobile */
  justify-content: center;
  margin-bottom: 20px;
}
@media (min-width: 769px) {
  .tabs-radio-wrap { display: flex; }
  .tabs-mobile-only { display: none !important; }
}

.tabs-radio {
  display: flex;
  align-items: center;
  position: relative;
  background: var(--bg-surface);
  border-radius: 99px;
  padding: 4px;
  gap: 0;
  box-shadow: 0 2px 12px rgba(0,0,0,0.2);
}

/* Hide native radio buttons */
.tabs-radio input[type="radio"] {
  display: none;
}

.tab-radio-label {
  display: flex;
  align-items: center;
  padding: 9px 20px;
  border-radius: 99px;
  cursor: pointer;
  font-size: 0.875rem;
  font-weight: 600;
  color: var(--text-muted);
  white-space: nowrap;
  position: relative;
  z-index: 2;
  transition: color 0.25s ease;
  user-select: none;
}

/* Active label text turns white */
.tabs-radio input[type="radio"]:checked + .tab-radio-label {
  color: #fff;
}

/* Glider — the sliding pill */
.tab-glider {
  position: absolute;
  height: calc(100% - 8px);
  top: 4px;
  left: 4px;
  border-radius: 99px;
  background: var(--btn-primary);
  z-index: 1;
  pointer-events: none;
  transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), width 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 2px 8px rgba(43,108,176,0.4);
}

/* ── Mobile: original pill button tabs ── */
.tabs-mobile-only {
  position: relative;
  display: flex;
  justify-content: center;
  gap: 4px;
  padding: 4px;
  background: var(--bg-surface);
  border-radius: 50px;
  margin-bottom: 20px;
  overflow-x: auto;
  scrollbar-width: none;
}
.tabs-mobile-only::-webkit-scrollbar { display: none; }
.tab-btn {
  padding: 10px 18px;
  border-radius: 50px;
  font-size: 0.85rem;
  font-weight: 600;
  color: var(--text-secondary);
  position: relative;
  z-index: 2;
  transition: color 0.15s;
  white-space: nowrap;
  flex-shrink: 0;
}
.tab-btn.active, .tab-btn:hover { color: var(--text-primary); }
.tab-indicator {
  position: absolute;
  top: 4px;
  bottom: 4px;
  border-radius: 50px;
  background: var(--btn-primary);
