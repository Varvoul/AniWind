  <!-- Page-specific JS -->
  <script>
    (function() {
      'use strict';

      const CONFIG = {
        TMDB_WORKER: 'https://aniocen.bionmovies47.workers.dev',
        ALLANIME_API: 'https://allanime-api.shashankbhake.codes',
        ANIMETHEMES_API: 'https://api.animethemes.moe/graphql',
        ANIMETHEMES_VIDEO: 'https://v.animethemes.moe',
        DEBOUNCE_MS: 300,
        BOOKMARK_AUTO_CLOSE_MS: 5000,
        ALERT_AUTO_CLOSE_MS: 3000
      };

      const GENRE_COLOR_MAP = {
        'a': 'data-start="a"', 'b': 'data-start="b"', 'c': 'data-start="c"',
        'd': 'data-start="d"', 'f': 'data-start="f"', 'h': 'data-start="h"',
        'm': 'data-start="m"', 'r': 'data-start="r"', 's': 'data-start="s"'
      };

      // Jikan Genre IDs for Sunken Treasures (18 popular genres)
      const JIKAN_GENRE_POOL = [1, 2, 4, 8, 10, 14, 22, 24, 37, 41, 46, 50, 62, 76, 81, 91, 104, 117];
      
      // Generate 30 unique 2-genre combinations for Sunken Treasures
      function generateGenreCombos(pool, count = 30) {
        const combos = [];
        for (let i = 0; i < pool.length && combos.length < count; i++) {
          for (let j = i + 1; j < pool.length && combos.length < count; j++) {
            combos.push([pool[i], pool[j]]);
          }
        }
        return combos.slice(0, count);
      }
      
      const SUNKEN_GENRE_COMBOS = generateGenreCombos(JIKAN_GENRE_POOL, 30);

      let currentState = {
        source: null, id: null, type: null, title: '',
        data: null, currentUser: null,
        selectedStatuses: [], dropdownTimer: null,
        bookmarkRowId: null, allAnimeData: null
      };

      document.addEventListener('DOMContentLoaded', async () => {
        // Prevent any auto-scrolling caused by hash/anchor or tab radio state on load
        if (window.location.hash) {
          history.replaceState(null, '', window.location.pathname + window.location.search);
        }
        window.scrollTo({ top: 0, behavior: 'instant' });
        setTimeout(() => window.scrollTo({ top: 0, behavior: 'instant' }), 50);

        // ── Parse URL first so currentState.id is set before any auth/bookmark calls ──
        parseUrl();
        initTabSwitching();

        // ── Auth (needs currentState.id already set) ──
        if (typeof window.supabaseClient !== 'undefined') await initAuth();

        if (currentState.id && currentState.source) {
          await fetchShowData();
          initUI();                          // wire up dropdown DOM first
          await fetchUserBookmarks();        // now fetch & render bookmark state
          if (currentState.source === 'jikan') {
            await Promise.all([
              loadSidebarContent(),
              loadRecommendations(),
              fetchAllAnimeData(currentState.data?.title)
            ]);
          } else {
            await Promise.all([
              loadSidebarContent(),
              loadRecommendations()
            ]);
          }
        } else {
          showError('Invalid show URL format');
        }
      });

      function parseUrl() {
        const path = window.location.pathname;
        const match = path.match(/\/info\/(anime|tv|movie)\/(jikan|tmdb-(?:tv|movie))-(\d+)(?:\/[^/]+)?/);
        
        if (!match) {
          console.error('URL does not match expected format:', path);
          showError('Invalid show URL format');
          return;
        }
        
        const [, pageType, sourcePrefix, idStr] = match;
        const id = parseInt(idStr, 10);
        
        currentState.type = pageType;
        currentState.id = id;
        
        if (sourcePrefix === 'jikan') {
          currentState.source = 'jikan';
          currentState.type = 'anime';
        } else if (sourcePrefix === 'tmdb-tv') {
          currentState.source = 'tmdb';
          currentState.type = 'tv';
        } else if (sourcePrefix === 'tmdb-movie') {
          currentState.source = 'tmdb';
          currentState.type = 'movie';
        }
      }

      async function initAuth() {
        // Listen for login/logout events that happen while the page is open
        window.supabaseClient.auth.onAuthStateChange(async (event, session) => {
          const prevUser = currentState.currentUser;
          currentState.currentUser = session?.user || null;
          // Only re-fetch bookmarks if the user changed (login/logout mid-session)
          // and currentState.id is already set (parseUrl has run)
          if (currentState.id && currentState.currentUser?.id !== prevUser?.id) {
            await fetchUserBookmarks();
          } else if (!currentState.currentUser) {
            // Logged out — reset bookmark UI
            currentState.selectedStatuses = [];
            currentState.bookmarkRowId = null;
            updateBookmarkUI();
          }
        });
        // Get the current session synchronously on page load
        const { data: { session } } = await window.supabaseClient.auth.getSession();
        currentState.currentUser = session?.user || null;
        // Do NOT call fetchUserBookmarks here — initUI hasn't run yet (DOM not ready)
      }

      async function fetchShowData() {
        try {
          if (currentState.source === 'jikan') await fetchJikanData();
          else if (currentState.source === 'tmdb') await fetchTMDBData();
          
          document.title = `${currentState.title} - Aniocean`;
          renderHero(); 
          renderStats(); 
          renderSynopsis(); 
          renderDetails();
          renderSeasons(); // async — runs independently, no await needed
          renderTabs();
          
        } catch (error) {
          console.error('Failed to fetch show data:', error);
          showError('Could not load show information. Please try again.');
        }
      }

      async function fetchJikanData() {
        const res = await fetch(`https://api.jikan.moe/v4/anime/${currentState.id}/full`);
        if (!res.ok) throw new Error(`Jikan API error: ${res.status}`);
        const { data } = await res.json();
        currentState.data = data;
        currentState.title = data.title_english || data.title || 'Unknown';
      }

      async function fetchTMDBData() {
        const endpoint = currentState.type;
        const workerUrl = `${CONFIG.TMDB_WORKER}/3/${endpoint}/${currentState.id}?append_to_response=credits,videos,external_ids,images,content_ratings,release_dates&include_image_language=en,null`;
        
        try {
          const res = await fetch(workerUrl);
          if (res.status === 500) throw new Error('TMDB Worker proxy error');
          if (!res.ok) throw new Error(`TMDB API error: ${res.status}`);
          
          const data = await res.json();
          if (!data.title && !data.name) throw new Error('Invalid TMDB response');
          
          currentState.data = data;
          currentState.title = data.title || data.name || 'Unknown';
        } catch (error) {
          console.error('TMDB fetch failed:', error);
          currentState.data = { title: currentState.title || 'Unknown', overview: '' };
          throw error;
        }
      }

      async function fetchAllAnimeData(query) {
        if (currentState.source !== 'jikan' || !query) return;
        try {
          // Use the English title or romaji title as search query
          const searchTitle = currentState.data?.title_english || query;
          const encoded = encodeURIComponent(searchTitle);
          const res = await fetch(`${CONFIG.ALLANIME_API}/search?query=${encoded}`);
          if (!res.ok) return;
          const results = await res.json();
          if (!Array.isArray(results)) return;
          
          const malId = currentState.id;
          // Priority 1: exact MAL id match
          let match = results.find(r => r.id === malId);
          // Priority 2: title similarity
          if (!match) {
            const qLower = (searchTitle || '').toLowerCase();
            match = results.find(r => r.title?.toLowerCase() === qLower)
              || results.find(r => r.title?.toLowerCase().includes(qLower) || qLower.includes(r.title?.toLowerCase()));
          }
          
          if (match) {
            currentState.allAnimeData = match;
            renderLanguageBadges(match.episodes_sub, match.episodes_dub);
            // Update episode display in details grid if already rendered
            updateEpisodeDetail(match.episodes_sub, match.episodes_dub);
          }
        } catch (e) { console.warn('AllAnime API fetch failed:', e); }
      }

      function updateEpisodeDetail(subCount, dubCount) {
        const epEl = document.getElementById('episodeDetailValue');
        if (!epEl) return;
        const data = currentState.data;
        const total = data.episodes || '?';
        let html = `<span>${total}</span>`;
        if (subCount > 0 || dubCount > 0) {
          html = `<span>${total}</span>`;
          if (subCount > 0) html += ` <span style="color:var(--text-muted);font-size:0.8em;">|</span> <i class="fa-solid fa-closed-captioning" style="color:#7ec8f7;" title="Subtitled"></i> ${subCount}`;
          if (dubCount > 0) html += ` <span style="color:var(--text-muted);font-size:0.8em;">|</span> <i class="fa-solid fa-microphone" style="color:#7ec8f7;" title="Dubbed"></i> ${dubCount}`;
        }
        epEl.innerHTML = html;
      }

      function renderHero() {
        const data = currentState.data;
        const isAnime = currentState.source === 'jikan';
        
        const typeNameMap = { 'anime': 'Anime', 'tv': 'TV Show', 'movie': 'Movie' };
        document.getElementById('typeName').textContent = typeNameMap[currentState.type] || currentState.type;
        document.getElementById('typeLink').href = `/type/${currentState.type}`;
        document.getElementById('breadcrumbTitle').textContent = currentState.title;
        
        const backdrop = isAnime 
          ? data.images?.jpg?.large_image_url 
          : data.backdrop_path 
            ? `https://image.tmdb.org/t/p/original${data.backdrop_path}` 
            : '';
        document.getElementById('backdropImg').src = backdrop || 'data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1600 600"><rect fill="%23131f2e" width="1600" height="600"/></svg>';
        
        const poster = isAnime 
          ? data.images?.jpg?.image_url 
          : data.poster_path 
            ? `https://image.tmdb.org/t/p/w500${data.poster_path}` 
            : '';
        document.getElementById('posterImg').src = poster || 'data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 300"><rect fill="%231e2633" width="200" height="300"/></svg>';
        
        document.getElementById('showTitle').textContent = currentState.title;
        
        const metaParts = [];
        const score = isAnime ? data.score : data.vote_average;
        if (score) metaParts.push(`★ ${score.toFixed(1)}`);
        metaParts.push(data.type || typeNameMap[currentState.type] || currentState.type);
        const studio = getFirstStudio(data, isAnime);
        if (studio) metaParts.push(studio);
        const duration = formatDuration(data.duration, isAnime, currentState.type);
        if (duration) metaParts.push(duration);
        
        document.getElementById('metadataRow').innerHTML = metaParts.map(m => `<span>${m}</span>`).join('');
        
        const slug = slugify(currentState.title);
        const watchPath = `/watch/${currentState.type}/${currentState.source}-${currentState.id}/${slug}`;
        document.getElementById('watchNowBtn').href = watchPath;
      }

      function slugify(title) {
        if (!title) return '';
        return title.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
      }

      function formatDuration(duration, isAnime, type) {
        if (!duration || duration === 'Unknown') return null;
        
        if (type === 'movie') {
          const match = duration.match(/(\d+)\s*min/);
          if (match) {
            const mins = parseInt(match[1]);
            const hours = Math.floor(mins / 60);
            const remaining = mins % 60;
            return hours > 0 ? `${hours}h ${remaining}min` : `${remaining}min`;
          }
          return duration;
        } else {
          return duration.replace(/ per ep.*/, '').replace(' min', ' min').trim();
        }
      }

      function getFirstStudio(data, isAnime) {
        if (isAnime) {
          return data.studios?.[0]?.name || null;
        } else {
          return data.production_companies?.[0]?.name || data.networks?.[0]?.name || null;
        }
      }

      function renderLanguageBadges(subCount, dubCount) {
        const container = document.getElementById('languageBadges');
        container.innerHTML = '';
        if (subCount > 0) container.innerHTML += `<span class="lang-badge sub"><i class="fa-solid fa-closed-captioning"></i> Sub ${subCount}ep</span>`;
        if (dubCount > 0) container.innerHTML += `<span class="lang-badge dub"><i class="fa-solid fa-microphone"></i> Dub ${dubCount}ep</span>`;
      }

      function renderStats() {
        const data = currentState.data;
        const isAnime = currentState.source === 'jikan';
        const platform = isAnime ? 'MAL' : 'TMDB';
        const rating = isAnime ? data.score : data.vote_average;
        const starColor = isAnime ? '#2e51a2' : '#01b4e4';
        
        document.getElementById('platformLabel').textContent = platform;
        document.getElementById('platformStar').style.color = starColor;
        document.getElementById('ratingValue').textContent = rating ? rating.toFixed(1) : 'N/A';
        document.getElementById('formatValue').textContent = data.type || currentState.type;
        
        // Duration — for TMDB use runtime (movie) or episode_run_time (TV)
        let duration = null;
        if (isAnime) {
          duration = formatDuration(data.duration, true, currentState.type);
        } else if (currentState.type === 'movie') {
          const mins = data.runtime;
          if (mins) {
            const h = Math.floor(mins / 60);
            const m = mins % 60;
            duration = h > 0 ? `${h}h ${m}min` : `${m}min`;
          }
        } else if (currentState.type === 'tv') {
          const runTimes = data.episode_run_time;
          if (runTimes?.length) duration = `${runTimes[0]} min`;
        }
        document.getElementById('durationValue').textContent = duration || '—';
        
        // Content rating
        let contentRating = '—';
        if (isAnime) {
          contentRating = data.rating ? data.rating.split(' - ')[0] : '—';
        } else if (currentState.type === 'movie') {
          const usRelease = data.release_dates?.results?.find(r => r.iso_3166_1 === 'US');
          contentRating = usRelease?.release_dates?.[0]?.certification || '—';
        } else if (currentState.type === 'tv') {
          const usRating = data.content_ratings?.results?.find(r => r.iso_3166_1 === 'US');
          contentRating = usRating?.rating || '—';
        }
        document.getElementById('contentRating').textContent = contentRating;
      }

      function renderSynopsis() {
        const data = currentState.data;
        const isAnime = currentState.source === 'jikan';
        document.getElementById('synopsisTitle').textContent = isAnime ? 'Synopsis' : 'Overview';
        const text = isAnime ? data.synopsis : data.overview;
        document.getElementById('synopsisText').textContent = text || 'No description available.';
      }

      function renderDetails() {
        const data = currentState.data;
        const isAnime = currentState.source === 'jikan';
        const grid = document.getElementById('detailsGrid');
        const details = [];
        
        if (isAnime) {
          if (data.title_english) details.push({ label: 'Title', value: data.title_english });
          // Romanji = data.title (the romaji/default title from Jikan, distinct from english)
          const romanji = data.title;
          if (romanji && romanji !== data.title_english) details.push({ label: 'Romanji', value: romanji });
          if (data.title_japanese) details.push({ label: 'Japanese', value: data.title_japanese });
          if (data.title_synonyms?.length) details.push({ label: 'Synonyms', value: data.title_synonyms.join(', ') });
        } else {
          if (data.title || data.name) details.push({ label: 'Title', value: data.title || data.name });
          if (data.original_title || data.original_name) details.push({ label: 'Original', value: data.original_title || data.original_name });
        }
        
        const country = isAnime ? 'Japan' : data.origin_country?.[0] || data.production_countries?.[0]?.iso_3166_1 || 'Unknown';
        details.push({ label: 'Country', value: country });
        
        if (isAnime && data.genres?.length) {
          const allGenres = [
            ...(data.genres?.map(g => g.name) || []),
            ...(data.themes?.map(g => g.name) || []),
            ...(data.demographics?.map(g => g.name) || [])
          ];
          const uniqueGenres = [...new Set(allGenres)];
          const genreHtml = uniqueGenres.map(name => {
            const firstChar = name.charAt(0).toLowerCase();
            const colorAttr = GENRE_COLOR_MAP[firstChar] || '';
            return `<a href="/genre/${name.toLowerCase().replace(/\s+/g, '-')}" class="genre-tag" ${colorAttr}>${name}</a>`;
          }).join('');
          details.push({ label: 'Genres', value: `<div class="genre-tags">${genreHtml}</div>`, isHtml: true });
        } else if (!isAnime && data.genres?.length) {
          const genreHtml = data.genres.map(g => {
            const name = g.name;
            const firstChar = name.charAt(0).toLowerCase();
            const colorAttr = GENRE_COLOR_MAP[firstChar] || '';
            return `<a href="/genre/${name.toLowerCase().replace(/\s+/g, '-')}" class="genre-tag" ${colorAttr}>${name}</a>`;
          }).join('');
          details.push({ label: 'Genres', value: `<div class="genre-tags">${genreHtml}</div>`, isHtml: true });
        }
        
        const status = isAnime ? data.status : (data.status === 'Released' ? 'Released' : data.status);
        details.push({ label: 'Status', value: status });
        
        if (isAnime && data.aired?.from) {
          const from = new Date(data.aired.from).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
          const to = data.aired.to ? new Date(data.aired.to).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : 'Ongoing';
          details.push({ label: 'Aired', value: `${from} to ${to}` });
        } else if (!isAnime) {
          const date = data.release_date || data.first_air_date;
          if (date) {
            const formatted = new Date(date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
            details.push({ label: data.release_date ? 'Released' : 'First Air Date', value: formatted });
          }
        }
        
        if (isAnime && data.season && data.year) {
          const season = data.season.charAt(0).toUpperCase() + data.season.slice(1);
          const seasonSlug = slugify(season);
          details.push({ 
            label: 'Premiered', 
            value: `<a href="/season/${seasonSlug}+${data.year}">${season} ${data.year}</a>`, 
            isHtml: true 
          });
        }
        
        if ((isAnime || currentState.type === 'tv') && data.broadcast?.string) {
          details.push({ label: 'Broadcast', value: data.broadcast.string });
        }
        
        if (currentState.type !== 'movie') {
          const episodes = isAnime ? data.episodes : data.number_of_episodes || data.number_of_seasons;
          if (episodes) {
            // Build episode HTML with sub/dub counts if available
            const allAnime = currentState.allAnimeData;
            let episodeHtml = `<span>${episodes}</span>`;
            if (isAnime && allAnime) {
