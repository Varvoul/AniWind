    // Filter out current show if on anime page
    const currentId = currentState.source === 'jikan' ? currentState.id : null;
    const results = currentId 
      ? data.data.filter(a => a.mal_id !== currentId)
      : data.data;
    
    // Restore opacity and render cards
    gridContainer.style.opacity = '1';
    
    if (results.length > 0) {
      console.log(`🎨 Rendering ${Math.min(24, results.length)} anime cards for page ${page}`);
      gridContainer.innerHTML = results.slice(0, 24).map(anime => renderAnimeRecCard(anime)).join('');
      
      // Update pagination with current page number
      renderSunkenPagination(page, SUNKEN_GENRE_COMBOS.length, paginationContainer);
      
      // Smooth scroll to section top
      gridContainer.scrollIntoView({ behavior: 'smooth', block: 'start' });
    } else {
      gridContainer.innerHTML = '<div class="loading-text" style="grid-column:1/-1;text-align:center;padding:40px 0;">No anime found for this combination</div>';
      renderSunkenPagination(page, SUNKEN_GENRE_COMBOS.length, paginationContainer);
    }
    
  } catch (error) {
    console.error('❌ Sunken Treasures error:', error);
    gridContainer.style.opacity = '1';
    gridContainer.innerHTML = `
      <div style="grid-column:1/-1;text-align:center;padding:40px 20px;">
        <i class="fa-solid fa-triangle-exclamation" style="font-size:2rem; color:var(--accent-gold); margin-bottom:10px; display:block;"></i>
        <p>Failed to load recommendations</p>
        <small style="color:var(--text-muted);">${error.message}</small>
      </div>
    `;
    // Re-render pagination so user can retry other pages
    renderSunkenPagination(page, SUNKEN_GENRE_COMBOS.length, paginationContainer);
  } finally {
    // Always restore interactivity
    gridContainer.style.opacity = '1';
    paginationContainer.classList.remove('loading');
  }
}

 // ✅ UPDATED: Matches index.html "Recently Completed" pagination style
function renderSunkenPagination(currentPage, totalPages, container) {
  container.innerHTML = '';
  container.className = 'pagination-nav';
  
  // Previous button (chevron on mobile, text on desktop)
  const prevBtn = document.createElement('button');
  prevBtn.type = 'button';
  prevBtn.className = 'btn btn-soft btn-prev rounded-full';
  prevBtn.innerHTML = '<span class="prev-text">Previous</span><span class="prev-chevron">‹</span>';
  prevBtn.disabled = currentPage === 1;
  prevBtn.onclick = (e) => {
    e.preventDefault();
    if (currentPage > 1) loadSunkenTreasures(currentPage - 1);
  };
  container.appendChild(prevBtn);
  
  // Page counter: "1 / 30"
  const pageCounter = document.createElement('div');
  pageCounter.className = 'page-counter';
  pageCounter.innerHTML = `<span class="current-page">${currentPage}</span> / <span class="total-pages">${totalPages}</span>`;
  container.appendChild(pageCounter);
  
  // Next button
  const nextBtn = document.createElement('button');
  nextBtn.type = 'button';
  nextBtn.className = 'btn btn-soft btn-next rounded-full';
  nextBtn.innerHTML = '<span class="next-text">Next</span><span class="next-chevron">›</span>';
  nextBtn.disabled = currentPage === totalPages;
  nextBtn.onclick = (e) => {
    e.preventDefault();
    if (currentPage < totalPages) loadSunkenTreasures(currentPage + 1);
  };
  container.appendChild(nextBtn);
}

      // Unified anime card renderer for both sections
      function renderAnimeRecCard(anime) {
        const title = anime.title_english || anime.title || 'Unknown';
        const poster = anime.images?.jpg?.image_url || anime.images?.webp?.image_url || '';
        const score = anime.score;
        const year = anime.aired?.from?.slice(0, 4) || 'N/A';
        const episodes = anime.episodes || '?';
        const type = anime.type || 'TV';
        const slug = slugify(title);
        const detailsUrl = `/info/anime/jikan-${anime.mal_id}/${slug}`;
        
        // Fallback poster if image fails to load
        const posterStyle = poster 
          ? `background-image: url('${poster}')` 
          : `background: linear-gradient(135deg, var(--bg-surface), var(--bg-card))`;
        
        return `<a href="${detailsUrl}" class="rec-card">
          <div class="rec-poster" style="${posterStyle}">
            ${poster ? `<img src="${poster}" alt="${escapeHtml(title)}" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;">` : ''}
            <span class="quality-badge">${type}</span>
            <span class="score-badge"><i class="fa-solid fa-star"></i> ${score?.toFixed(1) || 'N/A'}</span>
            <div class="play-overlay">
              <svg viewBox="0 0 24 24">
                <polygon points="5,3 19,12 5,21" fill="white"/>
              </svg>
            </div>
          </div>
          <div class="rec-info">
            <div class="rec-meta">${episodes} eps · ${year}</div>
            <div class="rec-title">${escapeHtml(title)}</div>
          </div>
        </a>`;
      }

      async function loadCastData() {
        const container = document.getElementById('castList');
        const data = currentState.data;
        const isAnime = currentState.source === 'jikan';
        
        if (isAnime) {
          container.innerHTML = '<p class="loading-text" style="padding:20px 0;">Loading cast...</p>';
          try {
            const res = await fetch(`https://api.jikan.moe/v4/anime/${currentState.id}/characters`);
            if (!res.ok) throw new Error(`Jikan characters error: ${res.status}`);
            const { data: charsData } = await res.json();
            const chars = (charsData || []).sort((a, b) => {
              // Main roles first, then by favorites
              if (a.role === 'Main' && b.role !== 'Main') return -1;
              if (b.role === 'Main' && a.role !== 'Main') return 1;
              return (b.favorites || 0) - (a.favorites || 0);
            });
            
            if (!chars.length) {
              container.innerHTML = '<p class="loading-text">No cast data available</p>';
              return;
            }
            
            // Build list layout matching image 3 style
            const castRows = chars.slice(0, 20).map(c => {
              const character = c.character;
              const charImg = character.images?.jpg?.image_url || character.images?.webp?.image_url || '';
              const charName = character.name || 'Unknown';
              const role = c.role || 'Supporting';
              // Prefer Japanese VA, fallback to first
              const va = c.voice_actors?.find(v => v.language === 'Japanese') || c.voice_actors?.[0];
              const vaName = va ? va.person.name.replace(/,\s*/, ' ').split(' ').reverse().join(' ') : 'Unknown';
              const vaImg = va?.person?.images?.jpg?.image_url || '';
              const vaLang = va?.language || '';

              return `
                <div class="cast-row">
                  <a href="/character/${character.mal_id}/${slugify(charName)}" class="cast-char-side">
                    <img class="cast-portrait cast-char-portrait" src="${escapeHtml(charImg)}" alt="${escapeHtml(charName)}"
                      loading="lazy"
                      onerror="this.src='data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 60 90%22><rect fill=%22%231e2633%22 width=%2260%22 height=%2290%22/></svg>'">
                    <div class="cast-char-info">
                      <span class="cast-char-name">${escapeHtml(charName)}</span>
                      <span class="cast-role-badge ${role === 'Main' ? 'role-main' : 'role-supporting'}">${role.toUpperCase()}</span>
                    </div>
                  </a>
                  ${va ? `
                  <a href="/person/${va.person.mal_id}/${slugify(vaName)}" class="cast-va-side">
                    <div class="cast-va-info">
                      <span class="cast-va-name">${escapeHtml(vaName)}</span>
                      <span class="cast-va-lang">${escapeHtml(vaLang)}</span>
                    </div>
                    <img class="cast-portrait cast-va-portrait" src="${escapeHtml(vaImg)}" alt="${escapeHtml(vaName)}"
                      loading="lazy"
                      onerror="this.src='data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 60 90%22><rect fill=%22%231e2633%22 width=%2260%22 height=%2290%22/></svg>'">
                  </a>` : '<div class="cast-va-side cast-va-empty"></div>'}
                </div>
              `;
            }).join('');
            
            container.innerHTML = `<div class="cast-warp-container"><div class="cast-list-grid">${castRows}</div>`;
            
          } catch (e) {
            console.error('Cast fetch error:', e);
            container.innerHTML = '<p class="loading-text">Failed to load cast</p>';
          }
        } else {
          // TMDB cast — same row layout
          const cast = data.credits?.cast || [];
          if (!cast.length) {
            container.innerHTML = '<p class="loading-text">No cast data available</p>';
            return;
          }
          
          const castRows = cast.slice(0, 20).map(c => {
            const actorImg = c.profile_path ? `https://image.tmdb.org/t/p/w185${c.profile_path}` : '';
            const actorName = c.name || 'Unknown';
            const character = c.character || '';
            return `
              <div class="cast-row">
                <div class="cast-char-side" style="cursor:default;">
                  <img class="cast-portrait cast-char-portrait" src="${escapeHtml(actorImg)}" alt="${escapeHtml(actorName)}"
                    loading="lazy"
                    onerror="this.src='data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 60 90%22><rect fill=%22%231e2633%22 width=%2260%22 height=%2290%22/></svg>'">
                  <div class="cast-char-info">
                    <span class="cast-char-name">${escapeHtml(actorName)}</span>
                    <span class="cast-role-badge role-supporting">ACTOR</span>
                  </div>
                </div>
                <div class="cast-va-side">
                  <div class="cast-va-info">
                    <span class="cast-va-name">${escapeHtml(character)}</span>
                    <span class="cast-va-lang">Character</span>
