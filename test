      async function renderSeasons() {
        const section = document.getElementById('seasonsSection');
        const data = currentState.data;
        const isAnime = currentState.source === 'jikan';
        
        let seasons = [];
        if (isAnime) {
          const relationsArray = Array.isArray(data.relations) ? data.relations : [];
          const relatedAnime = [];
          for (const rel of relationsArray) {
            const relType = (rel.relation || '').toLowerCase();
            if (['prequel','sequel','side story','alternative version','alternative setting','spin-off'].includes(relType)) {
              for (const entry of (rel.entry || [])) {
                if (entry.type === 'anime') relatedAnime.push({ ...entry, relation: rel.relation });
              }
            }
          }
          seasons = relatedAnime;
          if (!seasons.some(s => s.mal_id === currentState.id)) {
            seasons.unshift({ mal_id: currentState.id, name: currentState.title, type: 'anime', relation: 'Current' });
          }
        } else if (currentState.type === 'tv') {
          seasons = data.seasons?.filter(s => s.season_number > 0) || [];
        }
        
        if (!seasons.length) { section.style.display = 'none'; return; }
        
        section.style.display = 'block';
        const grid = document.getElementById('seasonsGrid');

        // For anime: show placeholder cards immediately, then fill images async
        if (isAnime) {
          // Render cards with placeholder first
          grid.innerHTML = seasons.map((season, idx) => {
            const seasonTitle = season.name || currentState.title;
            const slug = slugify(seasonTitle);
            const seasonUrl = `/info/anime/jikan-${season.mal_id}/${slug}`;
            const relationLabel = season.relation ? `<span class="season-relation-tag">${escapeHtml(season.relation)}</span>` : '';
            const isCurrent = season.mal_id === currentState.id;
            const currentImg = isCurrent
              ? (data.images?.jpg?.large_image_url || data.images?.jpg?.image_url || '')
              : '';
            return `<a href="${seasonUrl}" class="season-card" data-season-idx="${idx}">
              <img id="season-img-${idx}" src="${escapeHtml(currentImg)}" alt="${escapeHtml(seasonTitle)}" loading="lazy"
                style="${currentImg ? '' : 'display:none;'}"
                onerror="this.style.display='none'">
              <div class="season-img-placeholder" id="season-placeholder-${idx}" style="${currentImg ? 'display:none;' : ''}">
                <i class="fa-solid fa-film" style="font-size:2rem;opacity:0.3;"></i>
              </div>
              <div class="season-info-overlay">
                ${relationLabel}
                <span class="season-number">${escapeHtml(seasonTitle)}</span>
              </div>
            </a>`;
          }).join('');

          // Fetch images for non-current entries in background
          // Use a shared in-memory cache to avoid re-fetching on re-renders
          if (!window._jikanImgCache) window._jikanImgCache = {};

          seasons.forEach(async (season, idx) => {
            if (season.mal_id === currentState.id) return; // already have it from main data
            try {
              const cacheKey = `jikan_img_${season.mal_id}`;
              let imgUrl = window._jikanImgCache[cacheKey] || sessionStorage.getItem(cacheKey);

              if (!imgUrl) {
                // Stagger requests: 1s between each to stay well under Jikan's 3 req/sec limit
                await new Promise(r => setTimeout(r, idx * 1000));
                const res = await fetch(`https://api.jikan.moe/v4/anime/${season.mal_id}`);
                if (res.status === 429) {
                  // Rate limited — wait 2s and retry once
                  await new Promise(r => setTimeout(r, 2000));
                  const retry = await fetch(`https://api.jikan.moe/v4/anime/${season.mal_id}`);
                  if (!retry.ok) return;
                  const { data: animeData } = await retry.json();
                  imgUrl = animeData.images?.jpg?.large_image_url || animeData.images?.jpg?.image_url || '';
                } else if (!res.ok) {
                  return;
                } else {
                  const { data: animeData } = await res.json();
                  imgUrl = animeData.images?.jpg?.large_image_url || animeData.images?.jpg?.image_url || '';
                }
                if (imgUrl) {
                  window._jikanImgCache[cacheKey] = imgUrl;
                  try { sessionStorage.setItem(cacheKey, imgUrl); } catch(e) {}
                }
              }

              if (imgUrl) {
                const imgEl = document.getElementById(`season-img-${idx}`);
                const phEl = document.getElementById(`season-placeholder-${idx}`);
                if (imgEl) { imgEl.src = imgUrl; imgEl.style.display = ''; }
                if (phEl) phEl.style.display = 'none';
              }
            } catch (e) { console.warn(`Season image fetch failed for mal_id ${season.mal_id}:`, e); }
          });

        } else {
          // TMDB seasons already have poster_path
          grid.innerHTML = seasons.map(season => {
            const seasonTitle = season.name || currentState.title;
            const seasonNumber = season.season_number || 1;
            const slug = slugify(seasonTitle);
            const seasonUrl = `/info/tv/tmdb-tv-${currentState.id}/${slug}-season-${seasonNumber}`;
            const backdrop = season.poster_path ? `https://image.tmdb.org/t/p/w500${season.poster_path}` : '';
            return `<a href="${seasonUrl}" class="season-card">
              ${backdrop
                ? `<img src="${backdrop}" alt="${escapeHtml(seasonTitle)}" loading="lazy" onerror="this.style.display='none'">`
                : `<div class="season-img-placeholder"><i class="fa-solid fa-film" style="font-size:2rem;opacity:0.3;"></i></div>`}
              <div class="season-info-overlay">
                <span class="season-number">Season ${seasonNumber}</span>
              </div>
            </a>`;
          }).join('');
        }
      }

