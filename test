      async function loadThemesData() {
        const container = document.getElementById('themesContainer');
        if (currentState.source !== 'jikan') {
          container.innerHTML = '<p class="loading-text">Theme songs only available for anime</p>';
          return;
        }

        const malId = currentState.data?.mal_id || currentState.id;
        if (!malId) { container.innerHTML = '<p class="loading-text">No MAL ID available</p>'; return; }

        container.innerHTML = '<p class="loading-text" style="padding:20px 0;">Loading themes...</p>';

        try {
          // Correct REST endpoint — filter by MAL site + external_id, include song + entries + videos
          const url = `https://api.animethemes.moe/anime?filter[has]=resources&filter[site]=MyAnimeList&filter[external_id]=${malId}&include=animethemes.song,animethemes.animethemeentries.videos`;
          const res = await fetch(url);
          if (!res.ok) throw new Error(`AnimThemes error: ${res.status}`);
          const json = await res.json();
          const animeEntry = (json.anime || [])[0];

          if (!animeEntry?.animethemes?.length) {
            container.innerHTML = '<p class="loading-text">No theme songs found for this anime</p>';
            return;
          }

          const allThemes = animeEntry.animethemes;
          const ops = allThemes.filter(t => t.type === 'OP').sort((a, b) => (a.sequence || 0) - (b.sequence || 0));
          const eds = allThemes.filter(t => t.type === 'ED').sort((a, b) => (a.sequence || 0) - (b.sequence || 0));
          const posterImg = currentState.data.images?.jpg?.image_url || '';

          // Build a compact theme card: song title + artist row + collapsible video per version
          function buildThemeCards(list, sectionType) {
            return list.map(theme => {
              const seq      = theme.sequence || '';
              const label    = `${sectionType}${seq}`;
              const songTitle = theme.song?.title || label;
              // animethemes REST returns song.artists only when artists include is added;
              // the endpoint above includes animethemes.song so artists may not be present —
              // fall back gracefully
              const artists  = (theme.song?.artists || []).map(a => a.name).join(', ');

              // Collect all video entries across all versions
              const entries = theme.animethemeentries || [];
              const videoBlocks = entries.map(entry => {
                const video = entry.videos?.[0];
                if (!video?.link) return '';
                const verTag  = entry.version && entry.version > 1 ? ` <span class="theme-ver-tag">v${entry.version}</span>` : '';
                const epRange = entry.episodes ? `<span class="theme-ep-range">eps ${entry.episodes}</span>` : '';
                return `
                  <div class="theme-video-entry">
                    <div class="theme-video-meta">${verTag}${epRange}</div>
                    <div class="video-wrapper">
                      <video controls preload="none" ${posterImg ? `poster="${escapeHtml(posterImg)}"` : ''}>
                        <source src="${escapeHtml(video.link)}" type="video/webm">
                      </video>
                    </div>
                  </div>`;
              }).join('');

              if (!videoBlocks.trim()) return ''; // skip themes with no video

              return `
                <div class="theme-card">
                  <div class="theme-card-header">
                    <div class="theme-card-label">${escapeHtml(label)}</div>
                    <div class="theme-card-titles">
                      <span class="theme-song-title">${escapeHtml(songTitle)}</span>
                      ${artists ? `<span class="theme-artist"><i class="fa-solid fa-music" style="font-size:0.65rem;opacity:0.7;"></i> ${escapeHtml(artists)}</span>` : ''}
                    </div>
                  </div>
                  ${videoBlocks}
                </div>`;
            }).join('');
          }

          let html = '';
          if (ops.length) {
            html += `<div class="themes-section-heading"><i class="fa-solid fa-arrow-right-to-bracket" style="transform:rotate(-90deg);color:#7ec8f7;"></i> Opening Themes <span class="themes-count">${ops.length}</span></div>`;
            html += buildThemeCards(ops, 'OP');
          }
          if (eds.length) {
            html += `<div class="themes-section-heading" style="margin-top:20px;"><i class="fa-solid fa-arrow-right-from-bracket" style="transform:rotate(-90deg);color:#f6ad55;"></i> Ending Themes <span class="themes-count">${eds.length}</span></div>`;
            html += buildThemeCards(eds, 'ED');
          }

          container.innerHTML = html || '<p class="loading-text">No theme videos available</p>';

        } catch (e) {
          console.warn('AnimeThemes error:', e);
          container.innerHTML = '<p class="loading-text">Failed to load theme songs</p>';
        }
      }

      async function loadStatisticsData() {
        renderHistogram(); 
        renderSegmentedBar(); 
        renderMetricCards();
      }

      function renderHistogram() {
        const container = document.getElementById('scoreHistogram');
        const data = currentState.data;
        const isAnime = currentState.source === 'jikan';
        const avg = isAnime ? data.score : data.vote_average;
        const bars = [];
        for (let i = 1; i <= 10; i++) { 
          const distance = Math.abs(i - (avg || 7)); 
          const height = Math.max(5, 100 - distance * 15 + Math.random() * 10); 
          bars.push({ value: i, height: Math.min(100, Math.max(10, height)) }); 
        }
        container.innerHTML = bars.map(b => `<div class="hist-bar" style="height: ${b.height}%" data-value="${b.value}"></div>`).join('');
      }

      function renderSegmentedBar() {
        const container = document.getElementById('statusBar');
        const distribution = { watching: 25, completed: 45, planning: 20, dropped: 10 };
        const total = Object.values(distribution).reduce((a, b) => a + b, 0);
        container.innerHTML = Object.entries(distribution).map(([status, count]) => { 
          const width = (count / total) * 100; 
          return `<div class="status-segment status-${status}" style="width: ${width}%" title="${status}: ${count}%">${width > 15 ? `${count}%` : ''}</div>`; 
        }).join('');
      }

      function renderMetricCards() {
        const container = document.getElementById('metricCards');
        const data = currentState.data;
        const isAnime = currentState.source === 'jikan';
        const rank = isAnime ? data.rank : data.popularity;
        const popularity = isAnime ? data.popularity : data.vote_count;
        const members = isAnime ? data.members : data.popularity;
        container.innerHTML = `
          <div class="metric-card"><div class="metric-value">${rank ? `#${rank}` : '—'}</div><div class="metric-label">Rank</div><div class="metric-trend up">↑ 2 this week</div></div>
          <div class="metric-card"><div class="metric-value">${formatNumber(popularity)}</div><div class="metric-label">Popularity</div><div class="metric-trend up">↑ 5%</div></div>
          <div class="metric-card"><div class="metric-value">${formatNumber(members)}</div><div class="metric-label">Members</div><div class="metric-trend">+1.2k today</div></div>
        `;
      }

      function escapeHtml(str) { 
        if (!str) return ''; 
        const div = document.createElement('div'); 
        div.textContent = str; 
        return div.innerHTML; 
      }
      
      function formatNumber(num) { 
        if (num >= 1000000) return (num / 1000000).toFixed(1) + 'M'; 
        if (num >= 1000) return (num / 1000).toFixed(1) + 'K'; 
        return num.toString(); 
      }
      
      function showError(message) { 
        const main = document.querySelector('.main-content'); 
        main.innerHTML = `<div style="text-align: center; padding: 60px 20px; color: var(--text-muted);"><i class="fa-solid fa-triangle-exclamation" style="font-size: 3rem; margin-bottom: 16px; color: var(--accent-red);"></i><p style="font-size: 1.1rem;">${message}</p><a href="/" class="btn btn-primary" style="margin-top: 20px;">Return Home</a></div>`; 
      }
      
    })();
  </script>
