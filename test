      // Water Temple — genre-matched anime recommendations using the current show's actual genres
      async function loadWaterTemple() {
        const section = document.getElementById('waterTempleSection');
        const gridContainer = document.getElementById('waterTempleGrid');

        if (currentState.source !== 'jikan') { section.style.display = 'none'; return; }

        section.style.display = 'block';
        gridContainer.innerHTML = '<div class="loading-text">Loading recommendations...</div>';

        try {
          const data = currentState.data;

          // Collect all genre/theme/demographic MAL IDs from the current show
          // These come from show details: genres + themes + demographics
          const genreIds  = (data.genres       || []).map(g => g.mal_id).filter(Boolean);
          const themeIds  = (data.themes        || []).map(t => t.mal_id).filter(Boolean);
          const demoIds   = (data.demographics  || []).map(d => d.mal_id).filter(Boolean);

          // Use all genres for a broad, accurate match — up to 3 to stay within Jikan limits
          // Priority: genres first (most accurate), then demographics, then themes
          const combinedIds = [...new Set([...genreIds, ...demoIds, ...themeIds])];
          const selectedGenres = combinedIds.slice(0, 3);

          // Random page 1–4 for variety on each visit without hitting empty pages
          const randomPage = Math.floor(Math.random() * 4) + 1;

          const params = new URLSearchParams({
            order_by:  'score',       // sort by score so results are genuinely good
            sort:      'desc',
            limit:     '24',
            sfw:       'true',
            type:      (data.type || 'tv').toLowerCase(),
            min_score: '6.0',
            max_score: '9.7',
            page:      String(randomPage)
          });

          if (selectedGenres.length > 0) params.append('genres', selectedGenres.join(','));

          const apiUrl = `https://api.jikan.moe/v4/anime?${params.toString()}`;

          // Cache key: genre ids + anime type + page — 10 min TTL for freshness+variety
          const cacheKey = `wt2_${selectedGenres.join('_')}_${(data.type||'tv').toLowerCase()}_p${randomPage}`;
          let results;

          const cached = localStorage.getItem(cacheKey);
          if (cached) {
            try {
              const { data: cd, timestamp } = JSON.parse(cached);
              if (Date.now() - timestamp < 10 * 60 * 1000) results = cd;
            } catch(e) {}
          }

          if (!results) {
            const response = await fetchWithRetry(apiUrl);
            const apiData  = await response.json();
            results = apiData.data || [];
            try { localStorage.setItem(cacheKey, JSON.stringify({ data: results, timestamp: Date.now() })); } catch(e) {}
          }

          // Filter out the current show itself
          const filtered = results.filter(a => a.mal_id !== currentState.id).slice(0, 24);

          if (filtered.length > 0) {
            gridContainer.innerHTML = filtered.map(anime => renderAnimeRecCard(anime)).join('');
          } else {
            // Fallback: top-scored anime of same type, no genre filter
            const fbParams = new URLSearchParams({ order_by: 'score', sort: 'desc', limit: '24', sfw: 'true', type: (data.type || 'tv').toLowerCase(), min_score: '7.5' });
            const fbRes  = await fetchWithRetry(`https://api.jikan.moe/v4/anime?${fbParams.toString()}`);
            const fbData = await fbRes.json();
            const fbFiltered = (fbData.data || []).filter(a => a.mal_id !== currentState.id).slice(0, 24);
            gridContainer.innerHTML = fbFiltered.length
              ? fbFiltered.map(anime => renderAnimeRecCard(anime)).join('')
              : '<div class="loading-text">No recommendations found</div>';
          }

        } catch (error) {
          console.error('❌ Water Temple error:', error);
          gridContainer.innerHTML = '<div class="loading-text">Failed to load recommendations</div>';
        }
      }

      // Recommend for You — TMDB movie/TV genre+popularity+score based recommendations
      async function loadRecommendForYou() {
        const section = document.getElementById('recommendForYouSection');
        const gridContainer = document.getElementById('recommendForYouGrid');

        if (currentState.source !== 'tmdb') { section.style.display = 'none'; return; }

        section.style.display = 'block';
        gridContainer.innerHTML = '<div class="loading-text">Loading recommendations...</div>';

        try {
          const data = currentState.data;
          const mediaType = currentState.type; // 'movie' or 'tv'

          // Extract genre IDs from current show
          const genreIds = (data.genres || []).map(g => g.id).filter(Boolean);

          // TMDB discover — match genres, filter by vote quality, sort by popularity+vote combo
          // We try two strategies and merge: TMDB /recommendations (official) + /discover (filtered)
          const [recsRes, discoverRes] = await Promise.all([
            // Strategy 1: TMDB's own recommendation engine for this show
            fetch(`${CONFIG.TMDB_WORKER}/3/${mediaType}/${currentState.id}/recommendations?page=1`),
            // Strategy 2: Discover with matching genres + quality filter
            (() => {
              const p = new URLSearchParams({
                sort_by:              'vote_average.desc',
                'vote_count.gte':     mediaType === 'movie' ? '200' : '100',
                'vote_average.gte':   '6.5',
                with_genres:          genreIds.slice(0, 3).join(','),
                without_genres:       '',   // no exclusions — keep broad
                page:                 '1'
              });
              return fetch(`${CONFIG.TMDB_WORKER}/3/discover/${mediaType}?${p.toString()}`);
            })()
          ]);

          const recsData    = recsRes.ok    ? await recsRes.json()    : { results: [] };
          const discoverData = discoverRes.ok ? await discoverRes.json() : { results: [] };

          // Merge, de-duplicate by id, remove current show, sort by vote_average desc
          const seen = new Set([currentState.id]);
          const merged = [];

          for (const item of [...(recsData.results || []), ...(discoverData.results || [])]) {
            if (!item.id || seen.has(item.id)) continue;
            seen.add(item.id);
            merged.push(item);
          }

          // Sort: weighted score (vote_average × log10(vote_count+1)) for quality+popularity balance
          merged.sort((a, b) => {
            const scoreA = (a.vote_average || 0) * Math.log10((a.vote_count || 1) + 1);
            const scoreB = (b.vote_average || 0) * Math.log10((b.vote_count || 1) + 1);
            return scoreB - scoreA;
          });

          const final = merged.slice(0, 24);

          if (final.length > 0) {
            gridContainer.innerHTML = final.map(item => renderTMDBRecCard(item, mediaType)).join('');
          } else {
            // Fallback: popular content of same type
            const fbRes  = await fetch(`${CONFIG.TMDB_WORKER}/3/${mediaType}/popular?page=1`);
            const fbData = fbRes.ok ? await fbRes.json() : { results: [] };
            const fbFinal = (fbData.results || []).filter(i => i.id !== currentState.id).slice(0, 24);
            gridContainer.innerHTML = fbFinal.length
              ? fbFinal.map(item => renderTMDBRecCard(item, mediaType)).join('')
              : '<div class="loading-text">No recommendations found</div>';
          }

        } catch (error) {
          console.error('❌ Recommend for You error:', error);
          gridContainer.innerHTML = '<div class="loading-text">Failed to load recommendations</div>';
        }
      }

