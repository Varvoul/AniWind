      function initUI() {
        const expandBtn = document.getElementById('expandSynopsis');
        const content = document.getElementById('synopsisContent');
        expandBtn.addEventListener('click', () => {
          const isExpanded = content.classList.toggle('expanded');
          expandBtn.classList.toggle('expanded', isExpanded);
          document.getElementById('expandText').textContent = isExpanded ? 'Collapse' : 'Expand';
        });
        
        const dropdownBtn = document.getElementById('addToListBtn');
        const dropdown = document.getElementById('bookmarkDropdown');

        function closeDropdown(showNotification) {
          clearTimeout(currentState.dropdownTimer);
          currentState.dropdownTimer = null;
          dropdown.classList.remove('show');
          dropdownBtn.classList.remove('open');
          dropdownBtn.setAttribute('aria-expanded', 'false');
          if (showNotification) {
            showBookmarkToast(currentState.selectedStatuses);
          }
        }

        function startAutoCloseTimer() {
          clearTimeout(currentState.dropdownTimer);
          // After selecting the 1st status, give 3s to pick a 2nd before auto-closing
          currentState.dropdownTimer = setTimeout(() => {
            closeDropdown(true);
          }, 3000);
        }

        dropdownBtn.addEventListener('click', (e) => {
          e.stopPropagation();
          if (!currentState.currentUser) { showLoginAlert(); return; }
          const isOpen = !dropdown.classList.contains('show');
          if (isOpen) {
            dropdown.classList.add('show');
            dropdownBtn.classList.add('open');
            dropdownBtn.setAttribute('aria-expanded', 'true');
            // If already has 1 status selected, start the timer right away
            if (currentState.selectedStatuses.length === 1) startAutoCloseTimer();
          } else {
            closeDropdown(currentState.selectedStatuses.length > 0);
          }
        });

        // Close on outside click
        document.addEventListener('click', (e) => {
          if (dropdown.classList.contains('show') && !e.target.closest('.dropdown-container')) {
            closeDropdown(currentState.selectedStatuses.length > 0);
          }
        });

        document.querySelectorAll('.dropdown-item').forEach(item => {
          item.addEventListener('click', async (e) => {
            e.stopPropagation();
            const status = item.dataset.status;

            if (status === 'remove') {
              clearTimeout(currentState.dropdownTimer);
              await removeBookmark();
              dropdown.classList.remove('show');
              dropdownBtn.classList.remove('open');
              dropdownBtn.setAttribute('aria-expanded', 'false');
              return;
            }

            const idx = currentState.selectedStatuses.indexOf(status);
            if (idx > -1) {
              // Deselect
              currentState.selectedStatuses.splice(idx, 1);
            } else if (currentState.selectedStatuses.length < 2) {
              // Select
              currentState.selectedStatuses.push(status);
            } else {
              // Already at max (2) — ignore
              return;
            }

            updateBookmarkUI();
            await saveBookmarks();

            if (currentState.selectedStatuses.length >= 2) {
              // Got both picks — close immediately with toast
              closeDropdown(true);
            } else if (currentState.selectedStatuses.length === 1) {
              // 1 selected — start 3-second timer
              startAutoCloseTimer();
            } else {
              // Deselected all — restart timer or keep open
              clearTimeout(currentState.dropdownTimer);
              currentState.dropdownTimer = null;
            }
          });
        });
        
        document.getElementById('shareBtn').addEventListener('click', async () => {
          if (navigator.share) { 
            try { 
              await navigator.share({ 
                title: currentState.title, 
                text: `Check out ${currentState.title} on Aniocean!`, 
                url: window.location.href 
              }); 
            } catch (err) { 
              if (err.name !== 'AbortError') console.warn('Share failed:', err); 
            } 
          } else { 
            await navigator.clipboard.writeText(window.location.href); 
            showToast('Link copied to clipboard!'); 
          }
        });
        
        const lightbox = document.getElementById('artworkLightbox');
        document.getElementById('artworkGrid').addEventListener('click', (e) => { 
          const img = e.target.closest('img'); 
          if (img) { 
            document.getElementById('lightboxImg').src = img.src; 
            lightbox.classList.add('show'); 
          } 
        });
        document.getElementById('lightboxClose').addEventListener('click', () => lightbox.classList.remove('show'));
        lightbox.addEventListener('click', (e) => { if (e.target === lightbox) lightbox.classList.remove('show'); });
      }

      // Tab switching — handles both desktop radio/glider and mobile pill buttons
      function initTabSwitching() {
        const contents = document.querySelectorAll('.tab-content');
        const glider = document.querySelector('.tab-glider');

        // ── Shared: switch visible tab content ──────────────────
        function showTab(tabName) {
          contents.forEach(c => c.classList.remove('active'));
          const panel = document.getElementById(`${tabName}Tab`);
          if (panel) panel.classList.add('active');
        }

        // ── Desktop: radio labels + glider ──────────────────────
        const radioLabels = document.querySelectorAll('.tab-radio-label');

        function positionGlider(label) {
          if (!glider || !label) return;
          const track = label.closest('.tabs-radio');
          if (!track) return;
          const trackRect = track.getBoundingClientRect();
          const labelRect = label.getBoundingClientRect();
          glider.style.width = `${labelRect.width}px`;
          glider.style.transform = `translateX(${labelRect.left - trackRect.left}px)`;
        }

        radioLabels.forEach(label => {
          label.addEventListener('click', () => {
            showTab(label.dataset.tab);
            // Glider position updates after the browser reflects checked state
            requestAnimationFrame(() => positionGlider(label));
          });
        });

        // Initial glider position (double-rAF so layout is settled)
        requestAnimationFrame(() => requestAnimationFrame(() => {
          if (glider) glider.style.transition = 'none';
          const firstLabel = document.querySelector('.tab-radio-label');
          positionGlider(firstLabel);
          requestAnimationFrame(() => {
            if (glider) glider.style.transition = 'transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), width 0.3s';
          });
        }));

        // Reposition glider on resize
        window.addEventListener('resize', () => {
          const checkedRadio = document.querySelector('.tabs-radio input[type="radio"]:checked');
          if (checkedRadio) {
            const lbl = checkedRadio.nextElementSibling;
            positionGlider(lbl);
          }
        });

        // ── Mobile: pill button tabs + sliding indicator ─────────
        const tabs = document.querySelectorAll('.tab-btn');
        const indicator = document.getElementById('tabIndicator');

        function positionIndicator(activeTab) {
          if (!indicator || !activeTab) return;
          const container = activeTab.closest('.tabs-mobile-only');
          if (!container) return;
          const containerRect = container.getBoundingClientRect();
          const rect = activeTab.getBoundingClientRect();
          indicator.style.width = `${rect.width}px`;
          indicator.style.transform = `translateX(${rect.left - containerRect.left}px)`;
        }

        tabs.forEach(tab => {
          tab.addEventListener('click', () => {
            tabs.forEach(t => t.classList.remove('active'));
            tab.classList.add('active');
            positionIndicator(tab);
            showTab(tab.dataset.tab);
          });
        });

        // Initial mobile indicator position
        const activeTab = document.querySelector('.tab-btn.active');
        if (activeTab && indicator) {
          indicator.style.transition = 'none';
          requestAnimationFrame(() => requestAnimationFrame(() => {
            positionIndicator(activeTab);
            indicator.style.transition = 'transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), width 0.3s';
          }));
        }
      }

      // ═══════════════════════════════════════════
      // BOOKMARK SYSTEM — Supabase user_bookmarks
      // ═══════════════════════════════════════════

      // Status label map (for display)
      const STATUS_LABELS = {
        'planning':   'Planning to Watch',
        'watching':   'Watching',
        'completed':  'Completed',
        'rewatching': 'Re-watching',
        'dropped':    'Dropped',
        'favourite':  'My Favourite'
      };

      // Columns confirmed present from schema upgrade SQL.
      // If a column doesn't exist yet, Supabase returns PGRST204 "column not found".
      // We try the full payload first; if it fails we fall back to core-only columns.
      function buildBookmarkPayloadCore(statuses) {
        const show_id_int = parseInt(currentState.id) || null;
        const isAnime     = currentState.source === 'jikan';
        const d           = currentState.data;
        const mal_id      = isAnime  ? (parseInt(d.mal_id  || currentState.id) || null) : null;
        const tmdb_id     = !isAnime ? (parseInt(currentState.id)              || null) : null;
        const media_id    = `${currentState.source}-${currentState.id}`;
        const media_type  = currentState.type;

        // Get username from shared.js user profile if available
        const username = currentState.currentUser?.user_metadata?.username
          || currentState.currentUser?.email?.split('@')[0]
          || null;

        return {
          user_id:          currentState.currentUser.id,
          show_id:          show_id_int,
          media_id,
          media_type,
          bookmark_status:  statuses.join(','),
          mal_id,
          tmdb_id,
          username,
          updated_at:       new Date().toISOString()
        };
      }

      function buildBookmarkPayloadFull(statuses) {
        const core    = buildBookmarkPayloadCore(statuses);
        const d       = currentState.data;
        const isAnime = currentState.source === 'jikan';

        const mal_id  = core.mal_id;
        const tmdb_id = core.tmdb_id;

        return {
          ...core,

          // Titles
          eng_title:      isAnime ? (d.title_english || d.title || '') : (d.title || d.name || ''),
          default_title:  d.title || d.name || '',
          original_title: isAnime ? '' : (d.original_title || d.original_name || ''),
          romanji_title:  isAnime ? (d.title || '') : '',
          japanese_title: isAnime ? (d.title_japanese || '') : '',
          synonyms:       isAnime ? (d.title_synonyms || []).join(', ') : '',

          // Details
          country_name:        isAnime ? 'Japan' : (d.origin_country?.[0] || d.production_countries?.[0]?.iso_3166_1 || ''),
          genres:              (d.genres || []).map(g => g.name).join(', '),
          aired_date:          isAnime ? (d.aired?.string || '') : (d.release_date || d.first_air_date || ''),
          broadcast_day_time:  isAnime ? (d.broadcast?.string || '') : '',
          source:              isAnime ? (d.source || '') : '',
          rank:                isAnime ? (parseInt(d.rank)       || null) : null,
          popularity:          isAnime ? (parseInt(d.popularity) || null) : (Math.round(d.popularity) || null),
          studio_name:         isAnime ? (d.studios    || []).map(s => s.name).join(', ') : (d.production_companies || []).map(s => s.name).join(', '),
          producers_name:      isAnime ? (d.producers  || []).map(p => p.name).join(', ') : '',
          total_epi_num:       isAnime ? (parseInt(d.episodes) || null) : (parseInt(d.number_of_episodes) || null),
          dub_epi_num:         parseInt(currentState.allAnimeData?.episodes_dub) || null,
          sub_epi_num:         parseInt(currentState.allAnimeData?.episodes_sub) || null,
          format:              isAnime ? (d.type || '') : (currentState.type || ''),
          synopsis_context:    isAnime ? (d.synopsis || '') : '',
          overview_context:    !isAnime ? (d.overview || '') : '',
          mal_score:           isAnime  ? (parseFloat(d.score)        || null) : null,
          tmdb_average_score:  !isAnime ? (parseFloat(d.vote_average) || null) : null,
          content_rating:      isAnime  ? (d.rating ? d.rating.split(' - ')[0] : '') : '',
          anime_duration_time: isAnime  ? (d.duration || '') : '',
          tmdb_movie_tv_runtime: !isAnime ? (parseInt(d.runtime || d.episode_run_time?.[0]) || null) : null,
          show_poster_link:    isAnime  ? (d.images?.jpg?.image_url || '') : (d.poster_path ? `https://image.tmdb.org/t/p/w500${d.poster_path}` : ''),
          show_backdrop_landscape_image_link: isAnime ? (d.images?.jpg?.large_image_url || '') : (d.backdrop_path ? `https://image.tmdb.org/t/p/original${d.backdrop_path}` : ''),
          external_link_mal:   isAnime  ? `https://myanimelist.net/anime/${mal_id}` : '',
          external_link_tmdb:  !isAnime ? `https://www.themoviedb.org/${currentState.type}/${tmdb_id}` : ''
        };
      }

      async function fetchUserBookmarks() {
        if (!currentState.currentUser || !currentState.id) return;
        try {
          const { data, error } = await window.supabaseClient
            .from('user_bookmarks')
            .select('bookmark_status, id')
            .eq('user_id', currentState.currentUser.id)
            .eq('show_id', parseInt(currentState.id))
            .maybeSingle();

          if (error) { console.error('fetchUserBookmarks error:', error); return; }

          const rawStatus = data?.bookmark_status || '';
          if (data && rawStatus) {
            currentState.selectedStatuses = rawStatus
              .split(',')
              .map(s => s.trim())
              .filter(s => s.length > 0 && s !== 'remove');
            currentState.bookmarkRowId = data.id;
          } else {
            currentState.selectedStatuses = [];
            currentState.bookmarkRowId = null;
          }
          updateBookmarkUI();
        } catch (e) { console.error('fetchUserBookmarks exception:', e); }
      }

      async function upsertPayload(supa, payload) {
        const { data, error } = await supa
          .from('user_bookmarks')
          .upsert(payload, { onConflict: 'user_id,show_id' })
          .select('id')
          .maybeSingle();
        return { data, error };
      }

      async function saveBookmarks() {
        if (!currentState.currentUser) return;
        const supa = window.supabaseClient;
        try {
          if (currentState.selectedStatuses.length === 0) {
            if (currentState.bookmarkRowId) {
              const { error } = await supa
                .from('user_bookmarks')
                .delete()
                .eq('id', currentState.bookmarkRowId)
                .eq('user_id', currentState.currentUser.id);
              if (error) throw error;
              currentState.bookmarkRowId = null;
            }
            return;
          }

          // Try full payload first (all columns from migration SQL)
          const fullPayload = buildBookmarkPayloadFull(currentState.selectedStatuses);
          let { data, error } = await upsertPayload(supa, fullPayload);

          if (error) {
            // If full payload fails due to missing columns, fall back to core columns only
            const isColumnMissing = error.code === 'PGRST204' || 
              (error.message && error.message.includes('column'));
            if (isColumnMissing) {
              console.warn('[Bookmark] Full payload failed (missing columns), trying core-only:', error.message);
              const corePayload = buildBookmarkPayloadCore(currentState.selectedStatuses);
              const fallback = await upsertPayload(supa, corePayload);
